# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/nexusauth
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nexusauth

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=nexusauth_access_super_secret_key_change_this
JWT_REFRESH_SECRET=nexusauth_refresh_super_secret_key_change_this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Brevo (email service) ────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=your_sender_email@example.com
SENDER_NAME=NexusAuth

# ─── Client URL (CORS + email reset links) ───────────────────────────────────
# Also used to build the reset-password URL sent in forgot-password emails
CLIENT_URL=http://localhost:5173

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Get this from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JS Origins: http://localhost:5173 (dev), https://yourdomain.com (prod)
# Authorized Redirect URIs: not needed for GIS ID token flow
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
